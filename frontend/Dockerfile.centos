# =============================================================================
# Hydro O&M Copilot — Frontend (CentOS Stream 9)
# Multi-stage: Node.js 20 build → CentOS Stream 9 + nginx runtime
#
# K8s readiness:
#   - Non-root UID 1001 / GID 0 (OpenShift-compatible)
#   - BACKEND_URL injected at runtime via envsubst (no re-build needed)
#   - Serves static SPA + proxies /diagnosis/ and /health to backend
#   - In K8s: set BACKEND_URL=http://hydro-om-backend:8000 in Deployment env
# =============================================================================

# ── Stage 1: build (Node.js 20 on CentOS Stream 9) ───────────────────────────
FROM quay.io/centos/centos:stream9 AS builder

# Install Node.js 20 via NodeSource RPM repository
RUN dnf install -y curl \
    && curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - \
    && dnf install -y nodejs \
    && dnf clean all \
    && rm -rf /var/cache/dnf

WORKDIR /build

# Install dependencies first (layer-cache friendly)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source and build
COPY . .
# VITE_API_BASE_URL="" means same-origin (nginx handles the proxy)
ARG VITE_API_BASE_URL=""
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN npm run build


# ── Stage 2: runtime (CentOS Stream 9 + nginx) ───────────────────────────────
FROM quay.io/centos/centos:stream9 AS runtime

LABEL org.opencontainers.image.title="hydro-om-copilot-frontend" \
      org.opencontainers.image.description="Hydro O&M AI Copilot — React SPA frontend (nginx)" \
      org.opencontainers.image.source="https://github.com/rushwing/hydro-om-copilot" \
      org.opencontainers.image.licenses="MIT"

# nginx + gettext (provides envsubst for runtime config substitution)
RUN dnf install -y nginx gettext \
    && dnf clean all \
    && rm -rf /var/cache/dnf

# Copy built assets from builder stage
COPY --from=builder /build/dist /usr/share/nginx/html

# Install nginx config template (substituted at runtime via entrypoint)
COPY nginx.conf /etc/nginx/templates/default.conf.template
# Remove default nginx config
RUN rm -f /etc/nginx/conf.d/default.conf

# Copy and install entrypoint script
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Adjust nginx to run as non-root:
#   - pid file in /tmp (writable by non-root)
#   - logs to stdout/stderr (K8s-friendly)
RUN sed -i 's|pid /run/nginx.pid;|pid /tmp/nginx.pid;|' /etc/nginx/nginx.conf \
    && sed -i 's|/var/log/nginx/access.log|/dev/stdout|' /etc/nginx/nginx.conf \
    && sed -i 's|/var/log/nginx/error.log|/dev/stderr|' /etc/nginx/nginx.conf

# Non-root user (GID 0 for OpenShift compatibility)
RUN useradd -r -u 1001 -g 0 -s /sbin/nologin appuser \
    && chown -R 1001:0 \
        /usr/share/nginx/html \
        /etc/nginx/conf.d \
        /etc/nginx/templates \
        /var/cache/nginx \
        /var/log/nginx \
        /tmp \
    && chmod -R g=u \
        /usr/share/nginx/html \
        /etc/nginx/conf.d \
        /var/cache/nginx \
        /var/log/nginx

USER 1001

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=3s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:80/ > /dev/null || exit 1

ENTRYPOINT ["/docker-entrypoint.sh"]
